{
    "name": "vanilla/app",
    "description": "example of testing application",
    "type": "project",
    "require": {
        "php": "^8.5"
    },
    "require-dev": {
        "pestphp/pest": "^4.4",
        "phpunit/phpunit": "^12.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/App/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Test\\": "tests/Test/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": false
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    }
}